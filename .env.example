# ============================================================================
# Environment Variables Template
# ============================================================================
# Copy this file to .env and fill in your values
# For development: cp .env.example .env.development
# For production: cp .env.example .env.railway

# ============================================================================
# AWS Configuration
# ============================================================================
AWS_ACCESS_KEY=''
AWS_SECRET_KEY=''
AWS_BUCKET=''
AWS_TEST_BUCKET=''
AWS_REGION='eu-west-1'
CLOUDFRONT_NETWORK=''

# ============================================================================
# Authentication & Security
# ============================================================================
JWT_SECRET=''  # Minimum 32 characters, use a strong random string
JWT_EXPIRATION='30d'
STRONG_HASH=10

# ============================================================================
# Database Configuration
# ============================================================================
# For local development with Docker:
# DB_HOST='localhost'
# DB_PORT='3308'

# For Railway (external access):
# DB_HOST='maglev.proxy.rlwy.net'
# DB_PORT='43930'

# For Railway (internal network):
# DB_HOST='mysql.railway.internal'
# DB_PORT='3306'

DB_HOST=''
DB_PORT=''
DB_USER=''
DB_PASSWORD=''
DB_NAME=''
DB_CLIENT='mysql2'

# ============================================================================
# Email Services (AWS SES)
# ============================================================================
EMAIL_DEVELOPMENT=''
SES_FROM_EMAIL='support@learlify.com'
SES_REPLY_TO_EMAIL='support@learlify.com'

# ============================================================================
# Payment Gateway
# ============================================================================
STRIPE_API_KEY=''  # Use sk_test_* for testing, sk_live_* for production

# ============================================================================
# Communication Services
# ============================================================================
TWILIO_API_ACCOUNT_SID=''
TWILIO_API_KEY_SID=''
TWILIO_API_KEY_SECRET=''

# ============================================================================
# Google Services
# ============================================================================
GOOGLE_API_KEY=''

# ============================================================================
# WebSocket Configuration
# ============================================================================
SOCKET_HASH=''

# ============================================================================
# Application Settings
# ============================================================================
NODE_ENV='development'  # development | production | test
HOST='localhost'        # Use '0.0.0.0' for Docker/Railway
PORT=3100
PAGINATION_LIMIT=10

# ============================================================================
# Redis (Optional)
# ============================================================================
REDIS_URL=''

# ============================================================================
# Web Push / PWA (VAPID)
# Generate keys with: npx web-push generate-vapid-keys
# ============================================================================
VAPID_PUBLIC_KEY=''
VAPID_PRIVATE_KEY=''
VAPID_CONTACT_EMAIL='support@learlify.com'

# ============================================================================
# Other Settings
# ============================================================================
USE_WIRELESS_CONFIGURATION=false
SSL_CERT=''
SSL_SECRET=''

# ============================================================================
# Test Database (Optional)
# ============================================================================
TEST_DB_HOST=''
TEST_DB_PORT=''
TEST_DB_USER=''
TEST_DB_PASSWORD=''
TEST_DB_NAME=''
TEST_DB_CLIENT='mysql2'
