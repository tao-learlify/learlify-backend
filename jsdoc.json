{
  "source": {
    "include": ["src"],
    "includePattern": ".js$",
    "excludePattern": "(node_modules/|docs)"
  },
  "plugins": ["plugins/markdown"],
  "templates": {
    "cleverLinks": true,
    "monospacesLinks": true
  },
  "opts": {
    "recurse": true,
    "destination": "./src/docs"
  }
}