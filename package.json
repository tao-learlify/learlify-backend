  "scripts": {
    "build": "rimraf dist && babel src -D --out-dir dist && node dist && node prod.js",
    "start": "cross-env NODE_ENV=development nodemon --watch .env --watch src --exec babel-node src --source-maps",
    "prod": "cross-env NODE_ENV=production npm run build",
    "test": "cross-env NODE_ENV=test jest --forceExit --runInBand",
    "test:coverage": "cross-env NODE_ENV=test jest --forceExit --runInBand --coverage",
    "seed": "npx knex seed:run --knexfile src/config/knexfile.js",
    "migrate": "npx knex migrate:latest --knexfile src/config/knexfile.js",
    "rollback": "npx knex migrate:rollback --knexfile src/config/knexfile.js",
    "make:seeder": "npx knex seed:make --knexfile src/config/knexfile.js",
    "make:migration": "npx knex migrate:make --knexfile src/config/knexfile.js",
    "lint": "eslint \"src/**/*.js\"",
    "lint:fix": "eslint \"src/**/*.js\" --fix",
    "format": "prettier --write \"src/**/*.js\"",
    "docs": "jsdoc -c jsdoc.json",
    "access": "npx cross-env NODE_ENV=development npx babel-node src/scripts/access",
    "upgrade": "npx cross-env NODE_ENV=upgrade npx babel-node src/scripts/progress",
    "restart": "npx cross-env NODE_ENV=development npx babel-node src/scripts/restart.progress",
    "marking": "npx cross-env NODE_ENV=development npx babel-node src/scripts/marking",
    "merge": "npx cross-env NODE_ENV=development npx babel-node src/scripts/merge",
    "assets": "npx cross-env NODE_ENV=development npx babel-node src/scripts/exams.images && npx cross-env NODE_ENV=development npx babel-node src/scripts/categories.images"
  },
  "keywords": [],
