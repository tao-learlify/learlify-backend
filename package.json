  "scripts": {
    "build": "rimraf dist && babel src -D --out-dir dist --extensions '.js,.ts' && node dist && node prod.js",
    "start": "cross-env NODE_ENV=development NODE_PATH=./src nodemon --legacy-watch --watch .env --watch src --exec babel-node --extensions '.ts,.js' src/index.ts --source-maps",
    "prod": "cross-env NODE_ENV=production npm run build",
    "test": "cross-env NODE_ENV=test jest --forceExit --runInBand",
    "test:coverage": "cross-env NODE_ENV=test jest --forceExit --runInBand --coverage",
    "seed": "npx knex seed:run --knexfile src/config/knexfile.ts",
    "migrate": "npx knex migrate:latest --knexfile src/config/knexfile.ts",
    "rollback": "npx knex migrate:rollback --knexfile src/config/knexfile.ts",
    "make:seeder": "npx knex seed:make --knexfile src/config/knexfile.ts",
    "make:migration": "npx knex migrate:make --knexfile src/config/knexfile.ts",
    "type-check": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "docs": "jsdoc -c jsdoc.json",
    "access": "npx cross-env NODE_ENV=development npx babel-node src/scripts/access.ts",
    "upgrade": "npx cross-env NODE_ENV=upgrade npx babel-node src/scripts/progress.ts",
    "restart": "npx cross-env NODE_ENV=development npx babel-node src/scripts/restart.progress.ts",
    "marking": "npx cross-env NODE_ENV=development npx babel-node src/scripts/marking.ts",
    "merge": "npx cross-env NODE_ENV=development npx babel-node src/scripts/merge.ts",
    "assets": "npx cross-env NODE_ENV=development npx babel-node src/scripts/exams.images.ts && npx cross-env NODE_ENV=development npx babel-node src/scripts/categories.images.ts"
  },
